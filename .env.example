# ------------------------------------------------------------------
# HexMapExplorer environment configuration
# Copy this file to `.env` and adjust the values. `.env` is gitignored.
# docker compose reads this file automatically.
# ------------------------------------------------------------------

# --- PostgreSQL ---
POSTGRES_USER=hexmap
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=hexa_app

# --- Backend ---
# Public port the app is served on (nginx -> SPA + /api proxy).
FRONTEND_PORT=8080

# CORS origin for the API. With the nginx proxy (prod) and the Vite proxy
# (dev) the API is same-origin, so "*" is fine. Tighten if you expose the
# backend port directly.
CORS_ORIGIN=*

# Password for the cache-admin panel (gear icon). Sent as x-admin-token.
# Default is "admin" — change it for any non-local deployment.
ADMIN_TOKEN=admin

# ------------------------------------------------------------------
# Local development only (running the backend with `npm run dev` outside
# Docker). docker compose builds DATABASE_URL from the POSTGRES_* values
# above, so you do NOT need to set it for the compose workflow.
# ------------------------------------------------------------------
# DATABASE_URL=postgres://hexmap:change_me_to_a_strong_password@localhost:5432/hexa_app
